# Clerk (required) — Dashboard → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend API (Vite bakes this in at build time).
# Local dev: omit to use http://127.0.0.1:8000 automatically.
#
# Vercel (frontend + Python API in one project, rewrites to /api): omit — the app uses same-origin relative URLs.
# Separate API host only: set origin, no trailing slash.
# VITE_API_BASE_URL=https://api.example.com

# Optional map style URL
# VITE_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
